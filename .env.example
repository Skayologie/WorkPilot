# ==============================================================
#  .env.example  —  Copy this to .env and fill in your values.
# ==============================================================

# Telegram Bot
# 1. Message @BotFather on Telegram, send /newbot, copy the token
# 2. Message your new bot, then open:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    Look for "chat":{"id": 123456789}
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# Claude CLI full path
# Run in PowerShell: (Get-Command claude).Source
CLAUDE_EXE=C:\Users\YourName\.local\bin\claude.exe

# Prefix for Windows Scheduled Task names (no spaces)
TASK_PREFIX=WorkPilot

# Project runner script (your equivalent of dabadoc-run.ps1)
# Leave blank if you don't use a project runner
PROJECT_RUN=D:\YourProject\bin\run.ps1

# VS Code workspace file to open on work begin
PROJECT_WORKSPACE=D:\YourProject.code-workspace

# Chrome tabs to open on work begin (pipe-separated)
CHROME_TABS=https://mail.google.com|https://github.com

# WSL distro name for Docker health checks (wsl --list to find yours)
WSL_DISTRO=Ubuntu

# Service ports to health-check in /doctor (leave blank to skip)
API_PORT=3000
FRONTEND_PORT=4200
FRONTEND2_PORT=
